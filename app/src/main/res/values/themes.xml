<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.WeekTech" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Cores principais do sistema -->
        <item name="colorPrimary">@color/blue_primary</item>
        <item name="colorAccent">@color/blue_primary</item>

        <!-- Cor do indicador da bottom nav (o azul clarinho) -->
        <item name="colorSecondaryContainer">@color/blue_light</item>

        <!-- Cor do cursor e dos campos quando selecionados -->
        <item name="colorControlActivated">@color/blue_primary</item>
        <item name="android:textCursorDrawable">@null</item>

        <!-- Estilo customizado para o Calendário -->
        <item name="android:datePickerDialogTheme">@style/CustomDatePickerDialog</item>
    </style>

    <!-- Estilo do Calendário para forçar o azul -->
    <style name="CustomDatePickerDialog" parent="Theme.Material3.Light.Dialog">
        <item name="colorPrimary">@color/blue_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorAccent">@color/blue_primary</item>

        <!-- Cor de fundo do calendário -->
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/blue_primary</item>

        <!-- Cor de variantes (usado em backgrounds de seleção secundários) -->
        <item name="colorSurfaceVariant">@color/blue_light</item>
        <item name="colorOnSurfaceVariant">@color/blue_primary</item>

        <!-- Força a cor azul nos botões de texto (OK/CANCELAR) -->
        <item name="android:buttonBarPositiveButtonStyle">@style/Widget.Material3.Button.TextButton</item>
        <item name="android:buttonBarNegativeButtonStyle">@style/Widget.Material3.Button.TextButton</item>
    </style>

    <style name="Theme.WeekTech" parent="Base.Theme.WeekTech" />
</resources>