<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1B3A6B"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="40dp"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Meu Perfil"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"/>

        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="64dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DADOS DO PARTICIPANTE"
                        android:textColor="#1B3A6B"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:id="@+id/tvPerfilNome"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nome do Usuário"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#1B3A6B"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvPerfilEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="email@exemplo.com"
                        android:textSize="14sp"
                        android:textColor="#666666"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tvPerfilRa"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RA: 000000"
                        android:textSize="14sp"
                        android:textColor="#444444"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvPerfilCurso"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Curso"
                        android:textSize="14sp"
                        android:textColor="#444444"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <Button
                android:id="@+id/btnFaq"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="12dp"
                android:backgroundTint="#E8EEF7"
                android:text="Perguntas Frequentes (FAQ)"
                android:textColor="#1B3A6B"
                android:textStyle="bold"
                app:cornerRadius="12dp"/>

            <Button
                android:id="@+id/btnSair"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:backgroundTint="#D32F2F"
                android:text="Sair da Conta"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                app:cornerRadius="12dp"/>

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="64dp"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        app:elevation="12dp"
        app:itemIconSize="24dp"
        app:itemPaddingTop="10dp"
        app:itemPaddingBottom="10dp"
        app:itemIconTint="@drawable/bottom_nav_color_selector"
        app:itemTextColor="@drawable/bottom_nav_color_selector"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>