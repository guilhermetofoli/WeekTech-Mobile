<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="3dp"
    app:cardUseCompatPadding="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvNomeProjeto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@+id/tvStatusBadge"
                android:fontFamily="@font/montserrat_bold"
                android:text="Nome do Projeto"
                android:textColor="#1B3A6B"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvStatusBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:background="#E1E4E8"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:text="PENDENTE"
                android:textColor="#6B7C93"
                android:textSize="10sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <TextView
            android:id="@+id/tvNomeAluno"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Aluno · RA"
            android:textColor="#6B7C93"
            android:textSize="12sp"
            android:layout_marginBottom="12dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E1E4E8"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/tvDescricaoProjeto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Descrição do projeto..."
            android:textColor="#444444"
            android:textSize="13sp"
            android:lineSpacingExtra="2dp"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:id="@+id/layoutAgendamento"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#F0F7FF"
            android:padding="8dp"
            android:gravity="center_vertical"
            android:visibility="gone"
            android:layout_marginBottom="8dp">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_schedule"
                app:tint="#1B3A6B"
                android:layout_marginEnd="6dp"/>

            <TextView
                android:id="@+id/tvAgendamentoInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Apresentação: 00/00 às 00:00"
                android:textColor="#1B3A6B"
                android:textSize="12sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnExcluirProjeto"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="REMOVER E TENTAR NOVAMENTE"
            android:backgroundTint="#D32F2F"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:cornerRadius="8dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>
